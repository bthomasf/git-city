# GitLab City - 基础配置
# GitLab 实例地址（注意不要以 / 结尾）
GITLAB_BASE_URL=https://gitlab.example.com
# GitLab 访问 Token（建议使用只读、受限权限）
GITLAB_TOKEN=glpat_your-gitlab-token

# GitLab City - 团队与项目范围
# 团队 Group ID，多个用英文逗号分隔，如：123,456
GITLAB_GROUP_IDS=123
# 额外需要纳入统计的项目 ID，多个用英文逗号分隔，可为空
GITLAB_PROJECT_IDS=

# GitLab City - 权重与风险配置（可选）
# 不同行为的权重：提交 / 合并请求 / 事项
GITLAB_WEIGHT_COMMIT=1
GITLAB_WEIGHT_MR=3
GITLAB_WEIGHT_ISSUE=0.5

# 针对特定项目设置权重，格式：projectId=weight，多项用英文逗号分隔
# 例如：123=2,456=0.5
GITLAB_PROJECT_WEIGHTS=

# Bus Factor 风险阈值（0-1 之间），默认 0.8
GITLAB_BUS_FACTOR_THRESHOLD=0.8
# Git City - Environment Variables
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub (personal access token for API calls)
GITHUB_TOKEN=ghp_your-github-token

# Stripe (optional - only needed for payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# AbacatePay (optional - BRL payments)
ABACATEPAY_API_KEY=abc_dev_your-key
ABACATEPAY_WEBHOOK_SECRET=your-webhook-secret

# Himetrica (optional - analytics)
NEXT_PUBLIC_HIMETRICA_API_KEY=hm_your-api-key

# Resend (optional - ad expiry emails)
RESEND_API_KEY=re_your-resend-key

# Vercel Cron secret
CRON_SECRET=your-cron-secret
