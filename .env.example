# =============================================================================
# GitLab City - 环境变量示例
# 复制为 .env.local 并填写实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 应用
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# GitLab 连接（必填）
# -----------------------------------------------------------------------------
# GitLab 实例地址，勿以 / 结尾
GITLAB_BASE_URL=https://gitlab.example.com
# 具备只读权限的 Access Token
GITLAB_TOKEN=glpat_your-gitlab-token

# -----------------------------------------------------------------------------
# 项目范围（二选一）
# -----------------------------------------------------------------------------
# 方式一：扁平列表（未配置区域时使用）
# 团队 Group ID，多个用英文逗号分隔
GITLAB_GROUP_IDS=123
# 额外项目 ID，多个用英文逗号分隔，可为空
GITLAB_PROJECT_IDS=

# 方式二：区域-小区配置（推荐，多区域多小区多楼）
# 详见 docs/GITLAB-REGIONS-MIGRATION.md、docs/TEAM-GITLAB-CITY-DEPLOY.md
# GITLAB_REGIONS_CONFIG_JSON={"regions":[{"id":"r1","name":"业务线A","neighborhoods":[{"id":"n1","name":"项目组1","projectIds":[123,456]}]}]}

# -----------------------------------------------------------------------------
# 贡献权重与风险（可选）
# -----------------------------------------------------------------------------
# 行为权重：提交 / 合并请求 / Issue，默认 1 / 3 / 0.5
GITLAB_WEIGHT_COMMIT=1
GITLAB_WEIGHT_MR=3
GITLAB_WEIGHT_ISSUE=0.5
# 项目权重，格式：projectId=weight，多项逗号分隔，如 123=2,456=0.5
GITLAB_PROJECT_WEIGHTS=
# Bus Factor 风险阈值（0–1），默认 0.8
GITLAB_BUS_FACTOR_THRESHOLD=0.8

# -----------------------------------------------------------------------------
# 视觉规则（可选）
# -----------------------------------------------------------------------------
# 建筑高度与亮窗规则 JSON，不配置则使用内置默认，详见 docs/TEAM-GITLAB-CITY-DEPLOY.md
# GITLAB_VISUAL_RULES_JSON={"height":{"indicator":"score","minHeight":35,"maxHeight":600,"maxIndicatorValue":5000},"litPercentage":{"indicator":"score","minLit":0.2,"maxLit":0.9,"maxIndicatorValue":5000}}
# 或通过 URL 提供同上 JSON
# GITLAB_VISUAL_RULES_URL=https://your-config-server/visual-rules.json
